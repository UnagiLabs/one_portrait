#
# Public browser values.
# Safe to expose in the client bundle.
# `pnpm run build` reads local env files plus process.env and only requires
# `NEXT_PUBLIC_SUI_NETWORK` + `NEXT_PUBLIC_REGISTRY_OBJECT_ID`.
# `pnpm run build:cf` reads process.env only and requires all seven values
# below. In Cloudflare, set them as Build Variables; the checked-in
# `wrangler.jsonc` vars are runtime defaults for preview / deploy / upload and
# are not the build-time source of truth.
#
NEXT_PUBLIC_SUI_NETWORK=
NEXT_PUBLIC_REGISTRY_OBJECT_ID=
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_WALRUS_PUBLISHER=
NEXT_PUBLIC_WALRUS_AGGREGATOR=

#
# Server-only submit secret.
# Keep this in apps/web/.env.local for local development, and set the same key
# in the deployment environment for sponsored submit APIs.
# Required for the sponsored `submit_photo` smoke path.
#
ENOKI_PRIVATE_API_KEY=

#
# Deploy-time operator values.
# Do not commit real values here. Keep them in Cloudflare Secrets Store for
# deployed environments. When you run the generator on `manji` PC, the same
# values are also required in the generator process environment.
# The submit smoke path for issue #22 does not require these unless you also
# verify finalize/admin flows.
#
ADMIN_CAP_ID=
ADMIN_SUI_PRIVATE_KEY=

#
# Local generator stack.
# Required for `corepack pnpm --filter web run generator:tunnel`.
# `OP_LOCAL_TUNNEL_CONFIG_PATH` defaults to `~/.cloudflared/config.yml` when
# left blank. `OP_LOCAL_GENERATOR_PORT` defaults to `8080`.
#
OP_LOCAL_TUNNEL_NAME=
OP_LOCAL_TUNNEL_CONFIG_PATH=
OP_LOCAL_GENERATOR_PORT=

#
# Finalize dispatch bridge.
# `OP_GENERATOR_BASE_URL` points the web admin relay at the external generator.
# `OP_FINALIZE_DISPATCH_URL` points the Worker at the same generator.
# `OP_FINALIZE_DISPATCH_SECRET` is shared by web, Worker, and generator to
# block unauthorized `/dispatch` and generator admin calls over Cloudflare
# Tunnel.
#
OP_GENERATOR_BASE_URL=
OP_FINALIZE_DISPATCH_URL=
OP_FINALIZE_DISPATCH_SECRET=

#
# E2E-only. When set to "1", the app registers a Wallet Standard stub in
# place of the real Enoki / Google wallet. Leave blank in normal dev and smoke.
#
NEXT_PUBLIC_E2E_STUB_WALLET=
