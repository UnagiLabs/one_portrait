#
# Public browser values.
# Safe to expose in the client bundle.
# Non-secret deploy values are generated from ops/deployments/testnet.json.
# Stale values in .env.local are ignored when they overlap with the manifest.
#
NEXT_PUBLIC_SUI_NETWORK=
NEXT_PUBLIC_REGISTRY_OBJECT_ID=
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_WALRUS_PUBLISHER=
NEXT_PUBLIC_WALRUS_AGGREGATOR=

#
# Server-only submit secret.
# Keep this in apps/web/.env.local for local development, and set the same key
# in the deployment environment for sponsored submit APIs.
# Required for the sponsored `submit_photo` smoke path.
#
ENOKI_PRIVATE_API_KEY=

#
# Deploy-time operator secrets.
# ADMIN_CAP_ID is non-secret and generated from ops/deployments/testnet.json.
# Do not commit real ADMIN_SUI_PRIVATE_KEY values here. Keep them in Cloudflare
# Secrets Store for deployed environments. When you run the generator locally,
# the private key is still required in the generator process environment.
#
ADMIN_SUI_PRIVATE_KEY=

#
# Local generator stack.
# Required for `corepack pnpm --filter web run generator:tunnel`.
# `OP_LOCAL_TUNNEL_CONFIG_PATH` defaults to `~/.cloudflared/config.yml` when
# left blank. `OP_LOCAL_GENERATOR_PORT` defaults to `8080`.
#
OP_LOCAL_TUNNEL_NAME=
OP_LOCAL_TUNNEL_CONFIG_PATH=
OP_LOCAL_GENERATOR_PORT=

#
# Finalize dispatch bridge.
# `OP_GENERATOR_BASE_URL` points the web admin relay at the external generator.
# `OP_FINALIZE_DISPATCH_URL` points the Worker at the same generator.
# `OP_FINALIZE_DISPATCH_SECRET` is shared by web, Worker, and generator to
# block unauthorized `/dispatch` and generator admin calls over Cloudflare
# Tunnel.
#
OP_GENERATOR_BASE_URL=
OP_FINALIZE_DISPATCH_URL=
OP_FINALIZE_DISPATCH_SECRET=

#
# Demo unit finalize only. When a unit has `display_max_slots > max_slots`,
# the generator mixes mock tiles from this manifest to fill the mosaic.
# Leave blank for full-size units. `generator:tunnel` merge-loads apps/web
# env files, so setting it here forwards the value into the generator
# container. On-chain placements still only cover the actual submissions.
#
OP_DEMO_FINALIZE_MANIFEST=

#
# E2E-only. When set to "1", the app registers a Wallet Standard stub in
# place of the real Enoki / Google wallet. Leave blank in normal dev and smoke.
#
NEXT_PUBLIC_E2E_STUB_WALLET=

#
# Demo fixture mode. When set to "1", top / waiting room / gallery are
# rendered from demo fixtures instead of live Sui / Walrus state. Used by
# `pnpm run dev:demo`.
#
NEXT_PUBLIC_DEMO_MODE=

#
# Optional runtime overrides for the external generator. Leave blank to use
# the Cloudflare KV + local runtime-state resolution that `generator:tunnel`
# writes. Populate only when you need to force a specific URL or state path
# (e.g. preview finalize smoke against a fixed URL).
#
OP_GENERATOR_RUNTIME_URL_OVERRIDE=
OP_GENERATOR_RUNTIME_STATE_PATH=

#
# Optional explicit tunnel mode for `generator:tunnel`.
# Accepts "named" or "quick". Leave blank to auto-detect from
# `OP_LOCAL_TUNNEL_NAME` (named when set, quick when empty).
#
OP_LOCAL_TUNNEL_MODE=
