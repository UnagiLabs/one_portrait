{
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/**",
      "shared/**",
      "generator/**",
      "test/**",
      ".github/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.json",
      "tsconfig.base.json",
      "biome.json",
      "!apps/web/.next",
      "!apps/web/.open-next",
      "!apps/web/.e2e-xdg",
      "!apps/web/.wrangler",
      "!apps/web/playwright-report",
      "!apps/web/test-results",
      "!.claude",
      "!.codex",
      "!node_modules"
    ]
  },
  "formatter": {
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}
